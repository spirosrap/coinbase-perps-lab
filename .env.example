# Coinbase credential pairs
# Set one supported pair. The script prefers API_KEY_PERPS/API_SECRET_PERPS first.

API_KEY_PERPS=organizations/your-org/apiKeys/your-perps-key
API_SECRET_PERPS="-----BEGIN EC PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END EC PRIVATE KEY-----"

# Optional compatibility aliases
COINBASE_API_KEY=
COINBASE_API_SECRET=
API_KEY=
API_SECRET=

# Optional extra provider keys for future experiments in this workspace
OPENAI_API_KEY=
GEMINI_API_KEY=
